generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  image          String?
  canCreateGroup Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  groupMemberships        GroupMember[]
  createdGroups           Group[]                    @relation("GroupOwner")
  createdSessions         Session[]                  @relation("SessionCreator")
  sessionResults          SessionParticipantResult[]
  achievements            Achievement[]
  settlementsFrom         Settlement[]               @relation("SettlementFrom")
  settlementsTo           Settlement[]               @relation("SettlementTo")
  createdInvitations      EventInvitation[]          @relation("InvitationCreator")
  invitationResponses     InvitationResponse[]
  financialRequests       SessionFinancialRequest[]  @relation("RequestOwner")
  createdFinancialReqs    SessionFinancialRequest[]  @relation("RequestCreator")
  approvedFinancialReqs   SessionFinancialRequest[]  @relation("RequestApprover")
  declinedFinancialReqs   SessionFinancialRequest[]  @relation("RequestDecliner")

  expensesPaidBy          SessionExpense[]           @relation("ExpensePaidBy")
  expensesCreatedBy       SessionExpense[]           @relation("ExpenseCreatedBy")
  expenseChargesPaying    SessionExpenseCharge[]     @relation("ChargePayer")
  expenseChargesReceiving SessionExpenseCharge[]     @relation("ChargeReceiver")
  expenseChargesApproved  SessionExpenseCharge[]     @relation("ChargeApprovedBy")
  expenseChargesDeclined  SessionExpenseCharge[]     @relation("ChargeDeclinedBy")
}

model Group {
  id         String   @id @default(cuid())
  name       String
  image      String?
  inviteCode String   @unique @default(cuid())
  ownerId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner        User              @relation("GroupOwner", fields: [ownerId], references: [id])
  members      GroupMember[]
  sessions     Session[]
  seasons      Season[]
  achievements Achievement[]
  invitations  EventInvitation[]
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  isFrozen Boolean   @default(false)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model Season {
  id        String    @id @default(cuid())
  groupId   String
  name      String
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([groupId])
}

model Session {
  id          String        @id @default(cuid())
  groupId     String
  seasonId    String?
  date        DateTime
  location    String?
  notes       String?
  status      SessionStatus @default(OPEN)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  group               Group                      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  season              Season?                    @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdBy           User                       @relation("SessionCreator", fields: [createdById], references: [id])
  results             SessionParticipantResult[]
  settlements         Settlement[]
  achievements        Achievement[]
  financialRequests   SessionFinancialRequest[]
  invitation          EventInvitation?           @relation("InvitationSession")
  expenses            SessionExpense[]
}

enum SessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

model SessionParticipantResult {
  id            String    @id @default(cuid())
  sessionId     String
  userId        String
  buyIn         Float     @default(0)
  rebuy         Float     @default(0)
  addons        Float     @default(0)
  cashOut       Float     @default(0)
  totalInvested Float     @default(0)
  profitLoss    Float     @default(0)
  finalCashOut  Float     @default(0)
  maxDrawdown   Float     @default(0)
  isSubmitted   Boolean   @default(false)
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  sessionId String?
  type      String
  label     String
  value     Float?
  awardedAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, groupId])
}

model EventInvitation {
  id          String   @id @default(cuid())
  groupId     String
  title       String
  date        DateTime
  location    String?
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  sessionId   String?  @unique

  group     Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("InvitationCreator", fields: [createdById], references: [id])
  responses InvitationResponse[]
  session   Session?             @relation("InvitationSession", fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([groupId])
}

model InvitationResponse {
  id           String     @id @default(cuid())
  invitationId String
  userId       String
  status       RSVPStatus
  respondedAt  DateTime   @default(now())

  invitation EventInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([invitationId, userId])
}

enum RSVPStatus {
  COMING
  NOT_COMING
  MAYBE
}

model Settlement {
  id         String    @id @default(cuid())
  sessionId  String
  fromUserId String
  toUserId   String
  amount     Float
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromUser User    @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum FinancialRequestType {
  INITIAL_BUYIN
  REBUY
}

enum FinancialRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model SessionFinancialRequest {
  id               String                 @id @default(cuid())
  sessionId        String
  userId           String
  type             FinancialRequestType
  amount           Float
  status           FinancialRequestStatus @default(PENDING)
  createdAt        DateTime               @default(now())
  createdByUserId  String
  approvedAt       DateTime?
  approvedByUserId String?
  declinedAt       DateTime?
  declinedByUserId String?
  updatedAt        DateTime               @updatedAt

  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User    @relation("RequestOwner",    fields: [userId],           references: [id])
  createdBy   User    @relation("RequestCreator",  fields: [createdByUserId],  references: [id])
  approvedBy  User?   @relation("RequestApprover", fields: [approvedByUserId], references: [id])
  declinedBy  User?   @relation("RequestDecliner", fields: [declinedByUserId], references: [id])

  @@index([sessionId])
  @@index([sessionId, userId])
}

// ─── Session Expenses ───────────────────────────────────────────────────────

enum SplitMethod {
  EQUAL
  MANUAL
}

enum ExpenseChargeStatus {
  PENDING_PAYMENT
  PROOF_UPLOADED
  APPROVED
  DECLINED
  CANCELLED
}

model SessionExpense {
  id              String      @id @default(cuid())
  sessionId       String
  title           String
  description     String?
  totalAmount     Float
  paidByUserId    String
  splitMethod     SplitMethod @default(EQUAL)
  createdByUserId String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  session   Session                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  paidBy    User                   @relation("ExpensePaidBy",    fields: [paidByUserId],    references: [id])
  createdBy User                   @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id])
  charges   SessionExpenseCharge[]

  @@index([sessionId])
}

model SessionExpenseCharge {
  id               String              @id @default(cuid())
  expenseId        String
  payerUserId      String
  receiverUserId   String
  amount           Float
  status           ExpenseChargeStatus @default(PENDING_PAYMENT)
  proofImageUrl    String?
  paymentMarkedAt  DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  declinedAt       DateTime?
  declinedByUserId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  expense    SessionExpense @relation(fields: [expenseId],        references: [id], onDelete: Cascade)
  payer      User           @relation("ChargePayer",      fields: [payerUserId],      references: [id])
  receiver   User           @relation("ChargeReceiver",   fields: [receiverUserId],   references: [id])
  approvedBy User?          @relation("ChargeApprovedBy", fields: [approvedByUserId], references: [id])
  declinedBy User?          @relation("ChargeDeclinedBy", fields: [declinedByUserId], references: [id])

  @@index([expenseId])
}
